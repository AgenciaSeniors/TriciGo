# ===========================================
# TriciGo - Environment Variables
# Copy this file to .env and fill in values
# ===========================================

# Supabase (shared)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Expo apps (prefixed with EXPO_PUBLIC_ for client-side access)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_MAPBOX_TOKEN=your-mapbox-token

# Next.js admin (prefixed with NEXT_PUBLIC_ for client-side access)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (admin backend)
SUPABASE_JWT_SECRET=your-jwt-secret

# Sentry (error monitoring)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/123
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/123
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=tricigo

# PostHog (analytics)
EXPO_PUBLIC_POSTHOG_API_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_API_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

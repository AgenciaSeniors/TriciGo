{
  "expo": {
    "name": "TriciGo",
    "slug": "tricigo-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "tricigo",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo-wordmark-white.png",
      "backgroundColor": "#FF4D00",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.tricigo.client",
      "associatedDomains": [
        "applinks:tricigo.com"
      ],
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "NSLocationWhenInUseUsageDescription": "TriciGo necesita tu ubicación para encontrar conductores cercanos",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF4D00"
      },
      "package": "app.tricigo.client",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF4D00"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "TriciGo necesita tu ubicación para encontrar conductores cercanos."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsImpl": "mapbox"
        }
      ],
      "expo-secure-store",
      "expo-sharing"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "bb3c1a52-284b-476e-8a7d-8ef5f04b465e"
      }
    },
    "owner": "edua2005"
  }
}

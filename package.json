{
  "name": "tricigo",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:client": "turbo run dev --filter=@tricigo/client",
    "dev:driver": "turbo run dev --filter=@tricigo/driver",
    "dev:admin": "turbo run dev --filter=@tricigo/admin",
    "dev:web": "turbo run dev --filter=@tricigo/web",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.0",
      "react-dom": "19.2.0",
      "@types/react": "~19.2.14"
    }
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "turbo": "^2.7.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "expo-clipboard": "~55.0.9"
  }
}
